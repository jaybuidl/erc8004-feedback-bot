# Multi-chain template for the ERC-8004 Feedback Bot.
# Use either CHAINS JSON or suffix-based overrides. Suffixes are simpler.

NODE_ENV=production
CHAIN=sepolia
CHAIN_ID=11155111

# Base fallback values
GOLDSKY_ENDPOINT=https://example.invalid/graphql
PGTCR_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
PGTCR_ID=1

# Sepolia overrides
GOLDSKY_ENDPOINT_11155111=https://api.goldsky.com/api/public/<project>/subgraphs/<subgraph>/gn
PGTCR_REGISTRY_ADDRESS_11155111=0xYourSepoliaPgtcrRegistry
REPUTATION_REGISTRY_ADDRESS_11155111=0xYourSepoliaReputationRegistry
DATABASE_PATH_11155111=./data/bot-state-sepolia.db

# Mainnet overrides
# GOLDSKY_ENDPOINT_1=https://api.goldsky.com/api/public/<project>/subgraphs/<mainnet-subgraph>/gn
# PGTCR_REGISTRY_ADDRESS_1=0xYourMainnetPgtcrRegistry
# REPUTATION_REGISTRY_ADDRESS_1=0xYourMainnetReputationRegistry
# DATABASE_PATH_1=./data/bot-state-mainnet.db

SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=0xYourPrivateKey

# MIN_AGE_HOURS accepts decimals, so 0.5 means 30 minutes.
MIN_AGE_HOURS=72
FEEDBACK_VALUE=1
FEEDBACK_DECIMALS=0
FEEDBACK_TAG1=pgtcr_active
FEEDBACK_TAG2={{chainName}}
FEEDBACK_ENDPOINT=erc8004://pgtcr-feedback
FEEDBACK_TITLE_TEMPLATE=PGTCR collateralization active
FEEDBACK_TEXT_TEMPLATE=Agent {{agentIdDecimal}} has remained actively collateralized in PGTCR {{pgtcrId}} on {{chainName}} for {{daysActiveRounded}} days.
FEEDBACK_URI_MODE=generated
FEEDBACK_EXTRA_JSON={"chain":"{{chainName}}","pgtcrId":"{{pgtcrId}}","collateralizationId":"{{collateralizationId}}"}

DRY_RUN=true
REVOKE_ON_ABSENCE=true
ONCHAIN_DUPLICATE_PROTECTION=true
ONCHAIN_FEEDBACK_SCAN_LIMIT=100

MAX_BATCH_SIZE=10
FEEDBACK_BATCH_INTERVAL_MS=100
BATCH_PAUSE_MS=500
QUEUE_BATCH_PAUSE_MS=1000

LOG_LEVEL=info
ENABLE_METRICS=false
METRICS_PORT=3000
